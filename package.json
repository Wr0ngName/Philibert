{
  "name": "philibert",
  "productName": "Philibert",
  "version": "0.12.2",
  "description": "Desktop GUI for Claude Code - AI-powered coding assistant for non-technical users",
  "main": ".vite/build/index.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://dev.web.wr0ng.name/wrongname/philibert.git"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "vue-tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css,json}\"",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "claude",
    "ai",
    "coding-assistant",
    "gui",
    "vue"
  ],
  "author": {
    "name": "wrongname"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.2",
    "@types/dompurify": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "electron": "40.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^17.2.0",
    "happy-dom": "^20.4.0",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.1.10"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.121",
    "@anthropic-ai/claude-code": "^2.1.121",
    "@anthropic-ai/sdk": "^0.72.1",
    "@tailwindcss/typography": "^0.5.19",
    "dompurify": "^3.3.1",
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "marked": "^17.0.4",
    "node-pty": "^1.1.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.0"
  }
}
