#!/bin/bash
# Post-removal script for Philibert
# Prompts user about removing configuration data

set -e

APP_NAME="Philibert"
OLD_APP_NAMES=("ClineGUI" "Cline GUI" "cline-gui")

case "$1" in
    purge)
        # Called with 'apt purge' - remove all config without asking
        echo "Purging Philibert configuration data..."

        # Remove config for all users who have it
        for USER_HOME in /home/*; do
            if [ -d "$USER_HOME" ]; then
                USER_NAME=$(basename "$USER_HOME")

                for DIR_NAME in "$APP_NAME" "${OLD_APP_NAMES[@]}"; do
                    CONFIG_DIR="$USER_HOME/.config/$DIR_NAME"
                    if [ -d "$CONFIG_DIR" ]; then
                        rm -rf "$CONFIG_DIR"
                        echo "Removed $DIR_NAME configuration for user $USER_NAME"
                    fi
                done
            fi
        done

        # Also check root's config
        for DIR_NAME in "$APP_NAME" "${OLD_APP_NAMES[@]}"; do
            if [ -d "/root/.config/$DIR_NAME" ]; then
                rm -rf "/root/.config/$DIR_NAME"
                echo "Removed $DIR_NAME configuration for root"
            fi
        done
        ;;

    remove)
        # Called with 'apt remove' - ask user about keeping config
        echo ""
        echo "Philibert has been removed."
        echo ""
        echo "Your configuration and conversation history have been preserved in:"
        echo "  ~/.config/$APP_NAME/"
        echo ""
        echo "To completely remove all data, run:"
        echo "  sudo apt purge philibert"
        echo "  # or manually: rm -rf ~/.config/$APP_NAME/"
        echo ""
        ;;

    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Nothing to do for these cases
        ;;

    *)
        echo "postrm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0
