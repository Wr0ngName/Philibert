#!/bin/bash
# Post-removal script for Philibert (RPM)

APP_NAME="philibert"
OLD_APP_NAME="ClineGUI"

if [ "$1" = "0" ]; then
    # Package is being removed (not upgraded)
    echo ""
    echo "Philibert has been removed."
    echo ""
    echo "Your configuration and conversation history have been preserved in:"
    echo "  ~/.config/$APP_NAME"
    echo ""
    echo "To completely remove all data, run:"
    echo "  rm -rf ~/.config/$APP_NAME ~/.config/$OLD_APP_NAME"
    echo ""
fi

exit 0
